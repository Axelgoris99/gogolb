---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "../components/PostList.astro";
import { getCollection } from "astro:content";

// Get all blog posts and sort them by date
const allPosts = await getCollection("posts");
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf();
});

// Show up to 5 posts on the frontpage
const posts = sortedPosts.slice(0, 5).map((post) => ({
  ...post,
  url: `/posts/${post.id}`,
  frontmatter: post.data,
}));
---

<BaseLayout title="Welcome">
  <div class="max-w-4xl mx-auto">
    <section class="text-center py-[8vh]" transition:animate="fade">
      <h1 class="text-7xl mb-8 font-bold">Welcome to GoGolb !</h1>
      <p class="text-2xl text-muted-foreground max-w-3xl mx-auto mb-6">
        Hey. Welcome to my blog where I'll try to hit the right balance between
        technical and interesting.
      </p>
      <p class="text-muted-foreground">
        I do not intend to be exhaustive. There might be technical deep dive,
        high-level overview, get started, tutorials, etc. It will depend on my
        mood and what attracts most people!
      </p>
    </section>

    <section class="mx-auto" transition:animate="fade">
      <PostList
        posts={posts}
        showImages={false}
        showExcerpt={false}
        showSeparators={true}
        showTags={false}
      />

      <div class="text-center mt-24">
        <a
          href="/journal"
          class="text-lg font-medium text-black dark:text-white py-2 px-4 rounded-md inline-block focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 hover:underline"
        >
          View All Posts <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
